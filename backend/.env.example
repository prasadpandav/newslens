# Copy to .env and fill in. Everything works with no keys at all (mock mode).

# mock | groq | gemini | auto  (auto = groq first, gemini on rate-limit)
LLM_PROVIDER=mock

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional extra news source (200 free requests/day)
NEWSDATA_API_KEY=

# Hours between automatic pipeline runs
PIPELINE_INTERVAL_HOURS=3

DB_PATH=newslens.db
